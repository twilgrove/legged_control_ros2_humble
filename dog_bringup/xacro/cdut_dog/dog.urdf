    <minDepth>0.001</minDepth>
    <self_collide>1</self_collide>
    <sensor name="RH_contact_sensor" type="contact">
      <always_on>true</always_on>
      <update_rate>1000</update_rate>
      <contact>
        <collision>RH_FOOT_collision</collision>
      </contact>
    </sensor>
  </gazebo>
