  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>1000</update_rate>
      <imu>
        <orientation>
          <x>
            <noise type="gaussian">
              <stddev>0.034641016151377546</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <stddev>0.034641016151377546</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <stddev>0.034641016151377546</stddev>
            </noise>
          </z>
        </orientation>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <stddev>0.0</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <stddev>0.0</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <stddev>0.0</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </z>
        </linear_acceleration>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <stddev>0.02</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <stddev>0.02</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <stddev>0.02</stddev>
              <bias_mean>0.0</bias_mean>
            </noise>
          </z>
        </angular_velocity>
      </imu>
    </sensor>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>/home/cys/Project_Date/ROS2_workspace/dog_ws/install/dog_bringup/share/dog_bringup/config/robot_controllers.yaml</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_p3d.so" name="dog_ground_truth">
      <ros>
        <remapping>odom:=/ground_truth</remapping>
      </ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <update_rate>10.0</update_rate>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.001</gaussian_noise>
    </plugin>
  </gazebo>
</robot>
